<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="/css/style.css">
    <title>Admin Panel - Divya Darshan</title>
</head>
<body>
    <nav><h1>Admin Dashboard</h1></nav>
    <div class="container" style="max-width: 900px;">
        
        <h3>Registered Users</h3>
        <table border="1" style="width:100%; border-collapse: collapse; margin-bottom: 30px;">
            <tr style="background-color: #081A39; color: #FFD700;">
                <th>Name</th>
                <th>Email</th>
            </tr>
            <% users.forEach(user => { %>
                <tr>
                    <td><%= user.name %></td>
                    <td><%= user.email %></td>
                </tr>
            <% }) %>
        </table>

        <h3>All Darshan Bookings</h3>
        <table border="1" style="width:100%; border-collapse: collapse;">
            <tr style="background-color: #081A39; color: #FFD700;">
                <th>Temple</th>
                <th>Date</th>
                <th>Slot</th>
                <th>User Email</th>
            </tr>
            <% bookings.forEach(book => { %>
                <tr>
                    <td><%= book.temple %></td>
                    <td><%= book.date %></td>
                    <td><%= book.slot %></td>
                    <td><%= book.userEmail %></td>
                </tr>
            <% }) %>
        </table>
        
    </div>
</body>
</html>