<style>

/* ===== ROOT ===== */
:root {
    --navy: #081A39;
    --gold: #FFD700;
    --white: #fff;
    --glass: rgba(255,255,255,0.08);
}


/* ===== BODY ===== */
body {
    margin: 0;
    font-family: 'Poppins', sans-serif;
    background: var(--navy);
    color: white;
}

/* ===== NAVBAR ===== */
nav {
    display: flex;
    justify-content: space-between;
    padding: 15px 6%;
    background: rgba(255,255,255,0.95);
    position: sticky;
    top: 0;
    z-index: 1000;
}

.logo {
    font-family: 'Cinzel';
    font-weight: bold;
    color: var(--navy);
    text-decoration: none;
}

.nav-links {
    display: flex;
    gap: 25px;
    align-items: center;
}

.nav-links a {
    text-decoration: none;
    color: var(--navy);
    font-size: 0.9rem;
}

.signup-btn {
    background: var(--navy);
    color: var(--gold) !important;
    padding: 8px 20px;
    border-radius: 30px;
}

/* ===== HERO ===== */
.hero {
    display: flex;
    justify-content: space-between;
    padding: 80px 6%;
    gap: 50px;
    flex-wrap: wrap;
}

/* TEXT */
.hero-text {
    flex: 1;
}

.hero-text h1 {
    font-family: 'Cinzel';
    font-size: 3.5rem;
    margin: 0;
}

.highlight {
    color: var(--gold);
}

.hero-text p {
    margin: 25px 0;
    opacity: 0.8;
}

/* BUTTONS */
.btn {
    padding: 12px 30px;
    border-radius: 40px;
    text-decoration: none;
    font-size: 0.85rem;
    margin-right: 10px;
}

.primary {
    background: var(--gold);
    color: var(--navy);
}

.outline {
    border: 1px solid white;
    color: white;
}

/* ===== RIGHT SIDE ===== */
.side {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 20px;
}

/* QUOTE */
.quote {
    background: var(--glass);
    padding: 20px;
    border-radius: 15px;
    border-left: 4px solid var(--gold);
    text-align: center;
}

/* ===== CARD LAYOUT ===== */
.layout {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

/* TOP */
.top {
    display: flex;
    gap: 20px;
}

/* BOTTOM */
.bottom {
    display: flex;
    gap: 20px;
}

/* CARD */
.card {
    background: white;
    border-radius: 15px;
    overflow: hidden;
    flex: 1;
    transition: 0.4s;
}

.card:hover {
    transform: translateY(-10px);
}

/* IMAGE */
.card img {
    width: 100%;
    height: 150px;
    object-fit: cover;
}

/* BIG IMAGE */
.card.big img {
    height: 180px;
}

/* INFO */
.info {
    padding: 15px;
    text-align: center;
}

.info h3 {
    margin: 0;
    color: var(--navy);
}

.info p {
    margin: 5px 0 0;
    color: gray;
}

/* ===== FOOTER ===== */
.footer {
    text-align: center;
    padding: 60px;
    opacity: 0.7;
}

</style>
</head>

<body>

<!-- NAV -->
<nav>
